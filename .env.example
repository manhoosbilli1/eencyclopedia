# =============================================================================
# eencyclopedia — environment variables
# Copy to .env.local for development. Never commit .env.local.
# =============================================================================

# ----- Public site -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=eencyclopedia

# ----- Supabase --------------------------------------------------------------
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                  # server-only, bypasses RLS
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=                            # for migrations / direct connection

# ----- LLM providers ---------------------------------------------------------
# Primary: Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_OPUS=claude-opus-4-6

# Fallback (V1+): OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Embeddings (Voyage primary, OpenAI fallback)
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024

# ----- Stripe (V1+) ----------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=                           # price_xxx
STRIPE_PRICE_PRO_PLUS=                      # price_xxx

# ----- Rate limiting / cache -------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Observability ---------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# ----- Background jobs (V1+) -------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Email transactional ---------------------------------------------------
# Recommended: Resend (cheap, simple). Alt: Postmark, SES.
RESEND_API_KEY=
EMAIL_FROM=hello@eencyclopedia.com

# ----- Distributors (V1+) ----------------------------------------------------
MOUSER_API_KEY=
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
OCTOPART_API_KEY=
# LCSC has no official API; integration is scrape-based via shared cache.
LCSC_USER_AGENT="eencyclopedia/0.1 (contact: hello@eencyclopedia.com)"

# ----- Feature flags ---------------------------------------------------------
FEATURE_BILLING_ENABLED=false
FEATURE_SPICE_WASM_ENABLED=false
FEATURE_DISTRIBUTOR_PRICING_ENABLED=false
FEATURE_FORUM_ENABLED=false

# ----- Cost guardrails -------------------------------------------------------
# Hard daily $ cap per user. Beyond this, AI requests refuse with upgrade CTA.
AI_DAILY_USD_CAP_FREE=0.50
AI_DAILY_USD_CAP_PRO=2.00
AI_DAILY_USD_CAP_PRO_PLUS=10.00

# ----- Admin -----------------------------------------------------------------
ADMIN_EMAILS=krish.shoaib55@gmail.com
